{
  "name": "waline-vercel-test",
  "env": {
    "NODE_OPTIONS": "--experimental-require-module"
  },
  "builds": [
    {
      "src": "index.cjs",
      "use": "@vercel/node",
      "config": {
        "helpers": false,
        "includeFiles": "packages/server/node_modules/@mathjax/mathjax-newcm-font/**"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "index.cjs"
    }
  ]
}
