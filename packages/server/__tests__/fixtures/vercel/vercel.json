{
  "name": "waline-vercel-test",
  "env": {
    "NODE_OPTIONS": "--experimental-require-module"
  },
  "builds": [
    {
      "src": "index.cjs",
      "use": "@vercel/node",
      "config": {
        "helpers": false
      }
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "index.cjs"
    }
  ],
  "functions": {
    "/(.*)": {
      "includeFiles": ["node_modules/@mathjax/mathjax-newcm-font/**/*"]
    }
  }
}
